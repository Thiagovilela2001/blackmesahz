# ==========================================
# BLACKMESA WEBSITE - .gitignore
# ==========================================

# 1. Environment Variables & Secrets
# NUNCA comite credenciais, tokens, chaves de API, senhas ou arquivos .env!
.env
.env.*
!.env.example
*.pem
*.key
*.key.pub
*.cert
chaves/
*.crt
*.pfx
*.p12
*.jks

# 2. SvelteKit & Build Artifacts
# Ignorar as pastas geradas pelo build para evitar inchaço no repositório.
.svelte-kit/
build/
dist/
public/build/
*.tsbuildinfo
.goals/

# 3. Node Modules & Dependencies
# As dependências devem ser instaladas via npm install/yarn/pnpm e não comitadas.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 4. Banco de Dados / SQLite (Caso use arquivos locais no Rust/Supabase)
*.sqlite
*.sqlite3
*.db
*.db-journal
supabase/.temp/

# 5. Rust / Cargo Backend (se aplicável ao projeto principal)
/backend/target/
/backend/Cargo.lock

# 6. IDEs e Arquivos de Sistema Operacional
# Configurações do seu editor e sistema operacional não devem sujar o repo.
.claude/
.codex-vite*.log
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# 7. Backups locais / material duplicado fora do app
_backup/
*.7z

.vercel
