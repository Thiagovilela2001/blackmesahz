# Supabase (frontend — public keys only)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend CORS — set to your production frontend URL before deploying
# ALLOWED_ORIGIN=https://yourdomain.com
# Dev default (if unset): http://localhost:5173

# BLACKMESA Hz stream
# Local Icecast default:
PUBLIC_RADIO_STREAM_URL=http://127.0.0.1:8000/blackmesa.mp3

# Oracle radio backend API
PUBLIC_RADIO_API_URL=https://api.seu-dominio.com
